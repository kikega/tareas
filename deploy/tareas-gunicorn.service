[Unit]
Description=tareas gunicorn daemon
After=network.target

[Service]
User=kike
Group=kike
WorkingDirectory=/home/kike/proyectos/tareas
EnvironmentFile=/home/kike/proyectos/tareas/.env
ExecStart=/home/kike/proyectos/tareas/.venv/bin/gunicorn tareas.wsgi:application \
    --config /home/kike/proyectos/tareas/gunicorn.conf.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
